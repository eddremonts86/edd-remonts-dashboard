# edd-remonts-dashboard — Production Environment Configuration
# Copy this file to .env.production and fill in real values.
# See tasks/env-unification-plan.md for the full naming convention reference.
# NEVER commit .env.production — only .env.production.example is tracked.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://remonts.eduardoinerarte.dk

# ── Database (matches docker-compose.prod.yml) ────────────────────────────────
POSTGRES_USER=remonts
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=remonts_prod
DATABASE_URL=postgresql://remonts:change_me_strong_password@db:5432/remonts_prod

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_MODE=hybrid                       # local | clerk | hybrid
VITE_AUTH_MODE=hybrid
BETTER_AUTH_SECRET=change_me_generate_with_openssl  # openssl rand -base64 32
BETTER_AUTH_URL=https://remonts.eduardoinerarte.dk  # must match APP_URL
VITE_BETTER_AUTH_URL=https://remonts.eduardoinerarte.dk  # client-side mirror of BETTER_AUTH_URL (baked into Vite bundle)
# Clerk (required when AUTH_MODE=clerk or hybrid)
CLERK_SECRET_KEY=                      # sk_live_... from clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=            # pk_live_... from clerk.com → API Keys

# ── Default admin (consumed by scripts/db/seed-admin.ts at container start) ──
# REQUIRED in prod: if these are empty, seed-admin falls back to public defaults
# (edd_admin@local.com / Passw0rd!234) which would create a guessable admin.
DEFAULT_ADMIN_EMAIL=                   # e.g. admin@eduardoinerarte.dk
DEFAULT_ADMIN_PASSWORD=                # generate with: openssl rand -base64 24

# ── AI — Cloud Providers ──────────────────────────────────────────────────────
MINIMAX_API_KEY=your_minimax_api_key_here  # from platform.minimaxi.chat (primary LLM)
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
MINIMAX_MODEL=MiniMax-M1
OPENAI_API_KEY=                        # optional fallback
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=                     # optional fallback
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── Observability ─────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                       # from sentry.io → Project → DSN (empty = disabled)

# ── i18n ──────────────────────────────────────────────────────────────────────
VITE_DEFAULT_LOCALE=en                 # initial UI language: en | es | da

# ── Frontend → API base URL ───────────────────────────────────────────────────
VITE_API_URL=                          # absolute API base, leave empty for same-origin

# ── AI — Embeddings (RAG / vector search) ─────────────────────────────────────
CHROMADB_URL=http://chromadb:8000      # vector store endpoint (set if RAG is enabled)
AI_EMBEDDING_URL=                      # embedding provider URL (e.g. http://lmstudio:1234/v1)
AI_EMBEDDING_MODEL=                    # e.g. nomic-embed-text
AI_EMBEDDING_TIMEOUT_MS=30000          # request timeout for embedding calls

# ── AI — Generic API key (used when provider-specific key is missing) ─────────
AI_API_KEY=                            # generic fallback API key for AI calls

# ── AI — Self-hosted Provider Base URLs ───────────────────────────────────────
# Server-side reads AI_*_BASE_URL; client-side reads VITE_AI_*_BASE_URL.
AI_LLAMA_CPP_BASE_URL=                 # e.g. http://llama-cpp:8080/v1
VITE_AI_LLAMA_CPP_BASE_URL=
AI_OLLAMA_BASE_URL=                    # e.g. http://ollama:11434
VITE_AI_OLLAMA_BASE_URL=
AI_BASE_URL_INTERNAL=                  # internal cluster-only base URL for AI gateway
VITE_AI_LMSTUDIO_BASE_URL=             # LM Studio HTTP server (browser-reachable URL)

# ── AI — Cloud Provider Base URLs (client-side mirrors) ───────────────────────
VITE_AI_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_AI_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
VITE_AI_MINIMAX_BASE_URL=https://api.minimaxi.chat/v1
